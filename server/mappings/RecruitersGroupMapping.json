{
  "filename": "RecruitersGroupMapping",
  "description": "מיפוי קבוצות מגייסים - RecruitersGroups to recruitersgroup",
  "sourceTable": "RecruitersGroups",
  "targetTable": "recruitersgroup",
  "sourceIdColumn": "ID",
  "sourceQuery": "SELECT rg.*, COALESCE(rg.ProjectId, pstop.ProductId) AS ResolvedProjectId FROM RecruitersGroups rg WITH (NOLOCK) OUTER APPLY (SELECT TOP 1 ps.ProductId FROM ProductStock ps WITH (NOLOCK) WHERE ps.GroupId = rg.ID AND ps.ProductId IS NOT NULL) pstop",
  "whereClause": "ResolvedProjectId IS NOT NULL",
  "columnMappings": {
    "Name": {
      "convertType": "expression",
      "oldColumn": "Name",
      "expression": "value ? value.substring(0, 200) : 'ללא שם'"
    },
    "ProjectId": {
      "convertType": "direct",
      "oldColumn": "ResolvedProjectId",
      "useFkMapping": true,
      "comment": "COALESCE(RecruitersGroups.ProjectId, ProductStock.ProductId) -> id_mappings Project"
    },
    "RecordStatus": {
      "convertType": "const",
      "value": "2"
    },
    "StatusChangedAt": {
      "convertType": "const",
      "value": "GETDATE()"
    },
    "StatusChangedBy": {
      "convertType": "const",
      "value": "-1"
    },
    "CreatedAt": {
      "convertType": "const",
      "value": "GETDATE()"
    },
    "CreatedBy": {
      "convertType": "const",
      "value": "-1"
    },
    "UpdatedAt": {
      "convertType": "const",
      "value": "GETDATE()"
    },
    "UpdatedBy": {
      "convertType": "const",
      "value": "-1"
    }
  },
  "fkMappings": {
    "ProjectId": "Project"
  },
  "localizationMappings": {
    "targetTable": "recruitersgrouplanguage",
    "parentFkColumn": "RecruiterGroupId",
    "languageColumn": "LanguageId",
    "Name": {
      "hebrew": {
        "convertType": "expression",
        "oldColumn": "Name",
        "expression": "value ? value.substring(0, 200) : null"
      },
      "english": {
        "convertType": "expression",
        "oldColumn": "Name",
        "expression": "value ? value.substring(0, 200) : null"
      },
      "french": {
        "convertType": "expression",
        "oldColumn": "Name",
        "expression": "value ? value.substring(0, 200) : null"
      }
    },
    "Description": {
      "hebrew": { "convertType": "const", "value": null },
      "english": { "convertType": "const", "value": null },
      "french": { "convertType": "const", "value": null }
    },
    "DisplayInSite": {
      "hebrew": { "convertType": "const", "value": 1 },
      "english": { "convertType": "const", "value": 1 },
      "french": { "convertType": "const", "value": 1 }
    },
    "CreatedAt": { "convertType": "const", "value": "GETDATE()" },
    "CreatedBy": { "convertType": "const", "value": "-1" },
    "UpdatedAt": { "convertType": "const", "value": "GETDATE()" },
    "UpdatedBy": { "convertType": "const", "value": "-1" }
  },
  "notes": [
    "sourceQuery: OUTER APPLY מביא ProductId מ-ProductStock כדי לקבל ProjectId גם לקבוצות ללא ProjectId ישיר",
    "whereClause: מסנן קבוצות שלא ניתן לשייך לאף פרויקט (לא ProjectId ולא ProductStock)",
    "FK: ProjectId -> entity_type 'Project' ב-id_mappings",
    "סדר מיגרציה: RecruitersGroup חייב להיות לפני Recruiter"
  ]
}

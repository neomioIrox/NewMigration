{
  "filename": "ProjectMapping_Type3_Subs",
  "legacyMapping": { "sourceType": 1 },
  "sourceTable": "products",
  "sourceIdColumn": "productsid",
  "targetTable": "Project",
  "_meta": {
    "entityType": "Project",
    "sourceTable": "products",
    "targetTable": "Project",
    "sourcePrimaryKey": "productsid",
    "order": 5,
    "note": "Case 3 — ProductGroup campaign SUBS. Collapse mode: each sub becomes ONE ProjectItem under ONE parent campaign Project (no own Project/ProjectLocalization). Per decisions 2026-07-14: a multi-campaign sub gets a single item under a deterministically chosen parent (type3-sub-parent.json, written by scripts/migration/extract-scope-type3.js); products that are BOTH parent and sub are excluded from the subs scope (they keep only their own Project, so ProjectItem_certificate id_mappings are never overwritten and donations route to their own item)."
  },
  "preMigrationRunners": ["seed-project1"],
  "sourceQuery": "SELECT p.* FROM products p WITH (NOLOCK) WHERE EXISTS (SELECT 1 FROM ProductGroup g WITH (NOLOCK) WHERE g.SubProductId = p.productsid)",
  "scopeFilter": {
    "column": "productsid",
    "file": "type3-subs.json"
  },
  "parentProjectIdMapFile": "type3-sub-parent.json",
  "projectItemMappings": {
    "certificate": {
      "_comment": "Sub-product's own item under its parent campaign Project. ItemType by the sub's Certificate (1->2, 0->5). Recorded as ProjectItem_certificate keyed by the SUB productsid -> donation routing for sub orders.",
      "ItemName": {
        "convertType": "expression",
        "oldTable": "products",
        "oldColumn": "Name",
        "expression": "value ? value.substring(0, 150) : null"
      },
      "ItemType": {
        "convertType": "expression",
        "oldColumn": "Certificate",
        "expression": "row.Certificate == 1 ? 2 : 5"
      },
      "PriceType": {
        "convertType": "expression",
        "oldColumn": "Certificate",
        "expression": "row.Certificate == 1 ? 1 : 2"
      },
      "HasEngravingName": {
        "convertType": "expression",
        "oldColumn": "Certificate",
        "expression": "row.Certificate == 1 ? 1 : 0"
      },
      "AllowFreeAddPrayerNames": {
        "convertType": "expression",
        "oldTable": "products",
        "oldColumn": "ShowPrayerNames",
        "expression": "value ? 1 : 0",
        "defaultValue": 0
      },
      "DeliveryMethod": {
        "convertType": "expression",
        "oldColumn": "Certificate",
        "expression": "row.Certificate == 1 ? 1 : null"
      },
      "RecordStatus": {
        "convertType": "const",
        "value": "2"
      },
      "StatusChangedAt": {
        "convertType": "const",
        "value": "GETDATE()"
      },
      "StatusChangedBy": {
        "convertType": "const",
        "value": "-1"
      },
      "CreatedAt": {
        "convertType": "const",
        "value": "GETDATE()"
      },
      "CreatedBy": {
        "convertType": "const",
        "value": "-1"
      },
      "UpdatedAt": {
        "convertType": "const",
        "value": "GETDATE()"
      },
      "UpdatedBy": {
        "convertType": "const",
        "value": "-1"
      }
    }
  },
  "projectItemLocalizationMappings": {
    "hebrew": {
      "DisplayInSite": {
        "convertType": "expression",
        "oldColumn": "Hide",
        "expression": "(!row.Hide && row.ShowMainPage) ? 1 : 0"
      },
      "Title": {
        "convertType": "expression",
        "oldColumn": "ProjectNameForDonationPage",
        "expression": "(value && value !== row.Name) ? value.substring(0, 150) : (row.Name ? row.Name.substring(0, 150) : null)"
      },
      "PaymentSum": {
        "convertType": "expression",
        "oldColumn": "DefaultDonationSumFixed",
        "expression": "row.DefaultDonationSumFixed > 0 ? (row.DefaultDonationSumFixed * (row.DefaultPaymentsNumFixed || 1)) : row.DefaultDonationsSum"
      },
      "DefaultPaymentType": {
        "convertType": "expression",
        "oldColumn": "DefaultDonationSumFixed",
        "expression": "row.DefaultDonationSumFixed > 0 ? 1 : 2"
      },
      "DefaultPaymentsCount": {
        "convertType": "expression",
